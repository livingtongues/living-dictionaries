#!/bin/sh

export PATH="$HOME/.local/share/pnpm:$PATH"

# Pre-commit checks: test + check + lint:fix (lint scoped to site/ + root; the legacy/reference
# trees packages/ and site/e2e/ are ignored in eslint.config.js). lint:fix auto-formats
# then re-stages the already-staged files (mirrors house/example), so the auto-fixes land in the
# commit without pulling in files you didn't stage.
echo "Running pre-commit checks..."

# Tests run scoped: `vitest --changed` traces the module graph from all uncommitted changes
# (staged + unstaged + untracked) and runs only the affected test files. Blind spot: files loaded
# via import.meta.glob (the .sql migrations in shared-db.ts / dictionary-db.ts / history + the
# dict-client bundle) plus config/dep changes aren't in that graph — any of those flips the gate to
# the full suite.
changed_paths=$(git status --porcelain | awk '{ print $NF }')
full_run_triggers='\.sql$|^site/vitest\.config\.ts$|^site/package\.json$|^pnpm-lock\.yaml$'
if echo "$changed_paths" | grep -qE "$full_run_triggers"; then
    echo "→ vitest run (full suite — .sql/config/dep changes are not traceable by --changed)"
    pnpm --filter=site exec vitest run --reporter=dot
    test_status=$?
else
    echo "→ vitest run --changed"
    pnpm --filter=site exec vitest run --changed --reporter=dot
    test_status=$?
fi
if [ $test_status -ne 0 ]; then
    echo "❌ Tests failed. Commit aborted."
    exit 1
fi

echo "→ pnpm check"
pnpm check || { echo "❌ svelte-check failed. Commit aborted."; exit 1; }

echo "→ pnpm lint:fix"
pnpm lint:fix || { echo "❌ Lint failed. Commit aborted."; exit 1; }
# Re-stage only files that were already staged (in case lint:fix modified them)
git diff --cached --name-only --diff-filter=d | xargs -r git add

echo "✅ All pre-commit checks passed."
