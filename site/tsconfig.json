{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": [
      "vitest/globals",
      "vitest/importMeta"
    ],
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
