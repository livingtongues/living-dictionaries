# Committed dev defaults. Secrets live in `.env.local` (gitignored).
# Production overrides come from `/opt/hosting/sveltekit/.env` on the
# `living` VPS (loaded via docker-compose's `env_file` directive).

# Runtime mode flag. Read by anything that gates dev-only behavior via
# $env/static/public.
# - dev      → relative URLs, dev-mode OTP returns code inline (default for `pnpm dev`)
# - production → real OTP send, production absolute URLs
PUBLIC_MODE=dev

# Google Identity Services (one-tap / sign-in button). Public-by-design;
# safe to commit. Verifies the audience claim of Google-signed ID tokens
# server-side in `lib/auth/google.ts`. Reused from legacy LD per
# `.issues/migrate-supabase-users-to-new-site.md`.
PUBLIC_GOOGLE_OAUTH_CLIENT_ID=215143435444-fugm4gpav71r3l89n6i0iath4m436qnv.apps.googleusercontent.com

# AWS SES region. Non-secret. Carried over from legacy LD's `.env`.
AWS_SES_REGION=us-east-2
