#!/usr/bin/env bash

# Window 2
tmux new-window -dn scratch

# Window 1: nvim left, pnpm dev top-right, empty bottom-right
tmux split-window -h -c "$(pwd)"        # right pane becomes active
tmux split-window -v -c "$(pwd)"        # right-bottom becomes active
tmux select-pane -U                      # move to right-top
tmux send-keys "pnpm dev" Enter
tmux select-pane -L                      # move to left (nvim)
tmux send-keys "nvim ." Enter

clear
