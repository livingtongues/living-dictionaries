    "@typescript/native-preview": "^7.0.0-dev.20260508.1",
    "@unocss/svelte-scoped": "^66.6.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-look": "link:../../svelte-look",
    "typescript": "^6.0.3",
